#compdef chattor

autoload -U is-at-least

_chattor() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[Config directory path]:PATH:_default' \
'--config-dir=[Config directory path]:PATH:_default' \
'-t+[Theme preset (dark, light, cyberpunk, minimal, rose-pine, rose-pine-moon, rose-pine-dawn)]:NAME:_default' \
'--theme=[Theme preset (dark, light, cyberpunk, minimal, rose-pine, rose-pine-moon, rose-pine-dawn)]:NAME:_default' \
'-d[Enable debug logging]' \
'--debug[Enable debug logging]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
}

(( $+functions[_chattor_commands] )) ||
_chattor_commands() {
    local commands; commands=()
    _describe -t commands 'chattor commands' commands "$@"
}

if [ "$funcstack[1]" = "_chattor" ]; then
    _chattor "$@"
else
    compdef _chattor chattor
fi
