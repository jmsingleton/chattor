(( $+functions[_chattor_commands] )) ||
_chattor_commands() {
    local commands; commands=(
'tui:Run interactive TUI (default if no subcommand)' \
'daemon:Run headless daemon' \
'status:Show daemon status' \
'identity:Show own identity' \
'friends:Friend management' \
'send:Send a message' \
'recv:Receive unread messages' \
'listen:Stream incoming messages (blocking)' \
'channels:Channel management' \
'ephemeral:Set ephemeral message TTL' \
'notifications:Toggle notifications' \
'mcp:Start MCP server (stdio transport)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'chattor commands' commands "$@"
}
