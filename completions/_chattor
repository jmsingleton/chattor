;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_chattor__friends__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
