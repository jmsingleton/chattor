    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[Override config directory]:PATH:_default' \
'--config-dir=[Override config directory]:PATH:_default' \
'--data-dir=[Override data directory]:PATH:_default' \
'-d[Enable debug logging]' \
'--debug[Enable debug logging]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_chattor_commands" \
"*::: :->chattor" \
&& ret=0
