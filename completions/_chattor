    (chattor)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:chattor-command-$line[1]:"
        case $line[1] in
            (tui)
_arguments "${_arguments_options[@]}" : \
'-t+[Theme preset (dark, light, cyberpunk, minimal, rose-pine, rose-pine-moon, rose-pine-dawn)]:NAME:_default' \
